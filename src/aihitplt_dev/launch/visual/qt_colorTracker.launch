<launch>
    <arg name="VideoSwitch" default="false"/>
    <include file="$(find aihitplt_hardware_test)/QT_dev/launch/dev/qt_bringup.launch"/>
    <node pkg="aihitplt_astra" type="colorTracker_astra.py" name="colorTracker" required="true" output="screen"/>
    <node pkg="aihitplt_astra" type="colorHSV.py" name="colorHSV" required="true" output="screen" >
    </node>
</launch>
