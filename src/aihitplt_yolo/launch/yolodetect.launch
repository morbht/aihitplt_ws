<launch>
    <arg name="display" default="true"/>
    <arg name="camera_device" default="0"/>

    <!-- web_video_server -->
    <node pkg="web_video_server" type="web_video_server" name="web_video_server" output="screen"/>
    <node pkg="aihitplt_yolov4_tiny" type="msgToimg.py" name="msgToimg" required="true" output="screen"/>
    <node pkg="aihitplt_yolov4_tiny" type="yolov4_tiny.py" name="YoloDetect" output="screen" required="true" args="$(arg display)">
            <!-- 重映射输入话题 - 正确的位置 -->
        <param name="camera_device" value="$(arg camera_device)"/>
    </node>
</launch>


