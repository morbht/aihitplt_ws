<launch>
    <!-- 启动base.launch文件 -->
    <!-- Launch the base.launch file -->
    <include file="$(find aihitplt_laser)/launch/base.launch"/>
    <!-- 启动巡逻节点 Start patrol node -->
    <node pkg="aihitplt_laser" type="patrol.py" name="AgaPatrol" required="true" output="screen">
        <param name="circle_adjust" type="double" value="2.0"/>
    </node>
</launch>
