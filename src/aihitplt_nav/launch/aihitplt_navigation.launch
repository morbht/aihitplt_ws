<launch>
    <!-- 是否打开rviz || Whether to open rviz -->
    <arg name="use_rviz" default="true"/>
    <!-- 地图名 || Map name  map-->
    <arg name="map_name" default="aihitplt"/>
    <!-- MarkerArray node> -->
    <node name='send_mark' pkg="aihitplt_nav" type="send_mark.py"/>
    <!-- 加载地图 || Load map -->
    <node name="map_server" pkg="map_server" type="map_server" args="$(find aihitplt_nav)/maps/$(arg map_name).yaml"/>
    <!-- AMCL自适应蒙特卡洛定位 -->
    <include file="$(find aihitplt_nav)/launch/library/amcl.launch"/>
    <!-- 导航核心组件move_base -->
    <include file="$(find aihitplt_nav)/launch/library/move_base.launch"/>
    <!-- RVIZ -->
    <include file="$(find aihitplt_nav)/launch/view/view_navigate.launch" if="$(arg use_rviz)"/>
</launch>

