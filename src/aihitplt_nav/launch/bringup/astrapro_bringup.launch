<launch>

    <include file="$(find aihitplt_nav)/launch/library/astrapro.launch" >
    	<arg name="use_rgbd" default="false"/>
    </include>
    
    <include file="$(find aihitplt_bringup)/launch/aihitplt_bringup.launch" />
    
    <include file="$(find aihitplt_nav)/launch/library/depthimage_to_laserscan.launch">
        <arg name="scan_topic" default="scan" />
    </include>

    <!--node pkg="tf" type="static_transform_publisher" name="odom_to_camera_broadcaster" 
        args="0.1 0 0.05 0 0 0 odom_combined camera_link 100"/-->
    
    <node pkg="tf" type="static_transform_publisher" name="camera_to_base"
        args="0.1 0 0.15 0 0 0 base_link camera_link 100" />

</launch>
