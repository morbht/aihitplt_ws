<launch>
    <!-- Arguments -->
    <arg name="move_forward_only" default="true"/>
    <!-- move_base -->
    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <rosparam file="$(find aihitplt_nav)/param/common/global_costmap_params.yaml" command="load"/>
        <rosparam file="$(find aihitplt_nav)/param/common/local_costmap_params.yaml" command="load"/>
        <rosparam file="$(find aihitplt_nav)/param/common/move_base_params.yaml" command="load"/>
        <rosparam file="$(find aihitplt_nav)/param/common/costmap_common_params.yaml" command="load"
            ns="global_costmap"/>
        <rosparam file="$(find aihitplt_nav)/param/common/costmap_common_params.yaml" command="load"
            ns="local_costmap"/>
        <rosparam file="$(find aihitplt_nav)/param/common/dwa_local_planner_params.yaml" command="load"/>
        <param name="base_local_planner" type="string" value="dwa_local_planner/DWAPlannerROS"/>
        <!-- <param name="base_local_planner" type="string" value="teb_local_planner/TebLocalPlannerROS"/>-->
        <param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)"/>
        <remap from="cmd_vel" to="cmd_vel"/>
        <remap from="odom" to="odom"/>
    </node>
</launch>
