<?xml version="1.0"?>
<launch>
    <arg name="database_path" default="$(find aihitplt_nav)/maps/rtabmap.db"/>
    <arg name="rtabmapviz" default="true"/>
    <arg name="localization" default="true"/>
    <arg if="$(arg localization)" name="rtabmap_args" default=""/>
    <arg unless="$(arg localization)" name="rtabmap_args" default="-d"/>
    <arg name="rgb_topic" default="/camera/rgb/image_raw"/>
    <arg name="depth_topic" default="/camera/depth/image_raw"/>
    <arg name="camera_info_topic" default="/camera/rgb/camera_info"/>
    <arg name="wait_for_transform" default="0.2"/>
    
    <!-- Navigation with RTAB-Map (Localization mode) -->
    <node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen" args="$(arg rtabmap_args)">
        <param name="queue_size" value="10"/>
        <param name="database_path" type="string" value="$(arg database_path)"/>
        <param name="frame_id" type="string" value="base_footprint"/>
        
        <!-- TF settings -->
        <param name="odom_frame_id" value="/odom_combined"/>
        <param name="odom_tf_linear_variance" value="0.001"/>
        <param name="odom_tf_angular_variance" value="0.001"/>
        <param name="subscribe_depth" type="bool" value="true"/>
        <param name="subscribe_scan" type="bool" value="true"/>
        <param name="wait_for_transform_duration" type="double" value="$(arg wait_for_transform)"/>
        <param name="map_negative_poses_ignored" type="bool" value="true"/>
        
        <!-- Integration with move_base -->
        <param name="use_action_for_goal" type="bool" value="true"/>
        <remap from="move_base" to="/move_base"/>
        
        <!-- inputs -->
        <remap from="scan" to="/scan"/>
        <remap from="rgb/image" to="$(arg rgb_topic)"/>
        <remap from="depth/image" to="$(arg depth_topic)"/>
        <remap from="rgb/camera_info" to="$(arg camera_info_topic)"/>
        
        <!-- output -->
        <remap from="grid_map" to="/map"/>
        
        <!-- RTAB-Map's parameters -->
        <!-- Local loop closure detection -->
        <param name="RGBD/ProximityBySpace" type="string" value="true"/>
        <param name="RGBD/OptimizeFromGraphEnd" type="string" value="false"/>
        
        <!-- Loop Closure Detection -->
        <param name="Kp/DetectorStrategy" type="string" value="0"/>
        <param name="Kp/MaxFeatures" type="string" value="400"/>
        <param name="Kp/MaxDepth" type="string" value="8.0"/>
        
        <!-- ICP parameters -->
        <param name="Icp/VoxelSize" type="string" value="0.05"/>
        <param name="Icp/MaxCorrespondenceDistance" type="string" value="1.2"/>
        <param name="Icp/CorrespondenceRatio" type="string" value="0.3"/>
        
        <!-- Minimum visual inliers to accept loop closure -->
        <param name="Vis/MinInliers" type="string" value="50"/>
        <param name="Vis/InlierDistance" type="string" value="0.01"/>
        <param name="Rtabmap/TimeThr" type="string" value="0"/>
        <param name="Mem/RehearsalSimilarity" type="string" value="0.30"/>
        
        <!-- Rate at which new nodes are added to map -->
        <param name="Rtabmap/DetectionRate" type="string" value="1000"/>
        
        <!-- Loop closure transformation: 0=Visual, 1=ICP, 2=Visual+ICP -->
        <param name="Reg/Strategy" type="string" value="2"/>
        
        <!-- 2D SLAM -->
        <param name="Reg/Force3DoF" type="string" value="true"/>
        <param name="GridGlobal/MinSize" type="string" value="10"/>
        
        <!-- Localization mode - 关键修改 -->
        <param name="Mem/IncrementalMemory" type="string" value="false"/>
        <param name="Mem/InitWMWithAllNodes" type="string" value="true"/>
    </node>
</launch>
