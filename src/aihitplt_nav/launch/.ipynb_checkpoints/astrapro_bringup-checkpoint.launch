<launch>
    <!-- 驱动模块 || driver module -->
    <include file="$(find astra_camera)/launch/astrapro.launch"/>
    <include file="$(find aihitplt_bringup)/launch/bringup.launch"/>
    <include file="$(find aihitplt_nav)/launch/library/depthimage_to_laserscan.launch">
        <arg name="scan_topic" default="scan"/>
    </include>
    <!-- Coordinate conversion -->
    <node pkg="tf" type="static_transform_publisher" name="camera_link_to_laser"
          args="0 0 0 0 0 0  /camera_link /laser 50"/>
</launch>
