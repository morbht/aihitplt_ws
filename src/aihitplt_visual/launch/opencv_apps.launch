<launch>
    <arg name="img_flip" default="False"/>
    <include file="$(find usb_cam)/launch/usb_cam_no_display.launch"/>
    <node name="img_transform" pkg="aihitplt_visual" type="pub_image.py" output="screen">
        <param name="img_flip" type="bool" value="$(arg img_flip)"/>
        <remap from="/usb_cam/image_raw" to="/usb_cam/image_raw"/>
    </node>
    <!-- web_video_server -->
    <node pkg="web_video_server" type="web_video_server" name="web_video_server" output="screen"/>
</launch>
